{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "apps/**/*.ts",
    "libs/**/*.ts",
    "tools/**/*.ts",
    "scripts/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "Scrapling", ".beads", "tmp"]
}
