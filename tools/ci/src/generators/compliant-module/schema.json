{
  "$schema": "http://json-schema.org/schema",
  "$id": "CompliantModuleGenerator",
  "title": "Compliant module scaffold generator",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Module name. Uses kebab-case after normalization.",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "project": {
      "type": "string",
      "description": "Nx project name where module files are scaffolded."
    },
    "directory": {
      "type": "string",
      "description": "Optional directory under project sourceRoot."
    }
  },
  "required": ["name", "project"],
  "additionalProperties": false
}
