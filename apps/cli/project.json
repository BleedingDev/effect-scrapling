{
  "name": "cli-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cli/src",
  "projectType": "application",
  "implicitDependencies": ["foundation-core"],
  "tags": ["type:app", "scope:cli"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint apps/cli/src/**/*.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/cli/tsconfig.json"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/cli/tsconfig.json --outDir dist/apps/cli"
      },
      "outputs": ["{workspaceRoot}/dist/apps/cli"]
    }
  }
}
